import random
import string

def generate_password():
    length = 12
    
    special_characters = "@!#$%^&*()-=+:}]/"
    numbers = "1234567890"
    upper_characters = "ABCDEFGHIJKLMNOPQRSTUVWXYZ"
    lower_characters = upper_characters.lower()
    
    # Flags for including different character types
    special = True
    num = True
    up = True
    low = True
    
    X = ""
    
    if special:
        X += special_characters
    if num:
        X += numbers
    if up:
        X += upper_characters
    if low:
        X += lower_characters
        
    password = "".join(random.sample(X, length))
    
    return password

password = generate_password()
print(password)
